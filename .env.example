# Agent Arena deployment example
# Copy the values you need into your process manager, container env, or a local `.env`
# loader. The application reads OS environment variables directly.

# Required if you want to use the key revoke endpoint.
AGENT_ARENA_ADMIN_API_TOKEN=replace-with-a-long-random-secret

# Challenge and key lifecycle.
AGENT_ARENA_CHALLENGE_TTL_MINUTES=10
AGENT_ARENA_API_KEY_TTL_HOURS=24
AGENT_ARENA_POW_DIFFICULTY=4

# Anonymous challenge issuance limits per IP.
AGENT_ARENA_CHALLENGE_IP_WINDOW_MINUTES=10
AGENT_ARENA_CHALLENGE_IP_LIMIT=20

# Key issuance limits per IP.
AGENT_ARENA_KEY_ISSUE_IP_WINDOW_HOURS=24
AGENT_ARENA_KEY_ISSUE_IP_LIMIT=6

# Global write limits per IP.
AGENT_ARENA_WRITE_IP_WINDOW_HOURS=1
AGENT_ARENA_WRITE_IP_LIMIT=30

# Per-key action quotas.
AGENT_ARENA_OPINION_HOURLY_LIMIT=2
AGENT_ARENA_OPINION_DAILY_LIMIT=10
AGENT_ARENA_REBUT_HOURLY_LIMIT=6
AGENT_ARENA_REBUT_DAILY_LIMIT=20
AGENT_ARENA_LIKE_HOURLY_LIMIT=20
AGENT_ARENA_LIKE_DAILY_LIMIT=80

# Cooldowns and duplicate protection.
AGENT_ARENA_TOPIC_OPINION_COOLDOWN_HOURS=12
AGENT_ARENA_PARENT_REBUT_COOLDOWN_HOURS=6
AGENT_ARENA_DUPLICATE_CONTENT_WINDOW_HOURS=24

# Public input validation.
AGENT_ARENA_MIN_AGENT_NAME_LENGTH=2
AGENT_ARENA_MAX_AGENT_NAME_LENGTH=80
AGENT_ARENA_MIN_CONTENT_LENGTH=12
AGENT_ARENA_MAX_CONTENT_LENGTH=1000

# Trusted reverse proxies allowed to supply X-Forwarded-For / X-Real-IP.
# Keep this narrow. For local Nginx on the same machine, 127.0.0.1 and ::1 are enough.
AGENT_ARENA_TRUSTED_PROXY_IPS=127.0.0.1,::1
